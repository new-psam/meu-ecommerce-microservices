{
  "name": "catalogo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/catalogo/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-builders/custom-webpack:browser",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/catalogo",
        "index": "apps/catalogo/src/index.html",
        "main": "apps/catalogo/src/main.single-spa.ts",
        "tsConfig": "apps/catalogo/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/catalogo/public"
          }
        ],
        "styles": [
          "apps/catalogo/src/styles.scss"
        ],
        "customWebpackConfig": {
          "path": "apps/catalogo/extra-webpack.config.js",
          "libraryName": "catalogo",
          "libraryTarget": "umd"
        },
        "deployUrl": "http://localhost:4200/"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "none"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true,
          "outputHashing": "none"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-builders/custom-webpack:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "catalogo:build:production"
        },
        "development": {
          "buildTarget": "catalogo:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "catalogo:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/catalogo/jest.config.cts",
        "tsConfig": "apps/catalogo/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "catalogo:build",
        "spa": true
      }
    }
  }
}